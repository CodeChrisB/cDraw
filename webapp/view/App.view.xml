<mvc:View controllerName="ui5.walkthrough.controller.App"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core">
    
    <Page title="Drawflow Editor" class="sapUiContentPadding">

        <!-- Toolbar -->
        <VBox class="sapUiSmallMargin">
            <Toolbar>
                <Button text="Add Node" press=".onAddNode" />
                <Button text="Add Custom Node" press=".onAddCustomNode" />
                <Button text="Delete Selected Node" press=".onDeleteNode" />
                <Button text="Zoom In" press=".onZoomIn" />
                <Button text="Zoom Out" press=".onZoomOut" />
                <Button text="Export JSON" press=".onExport" />
                <Button text="Import JSON" press=".onImport" />
            </Toolbar>
        </VBox>

        <core:HTML id="drawflowHtml" preferDOM="true" style="width:100%; height:600px; border:1px solid #ccc;" />

    </Page>
</mvc:View>